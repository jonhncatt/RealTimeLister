OPENAI_API_KEY=

# Copy one of these templates to .env based on your network environment:
# - env.online.example
# - env.offline-model.example
# - env.hf-mirror.example

# Common settings
RT_TRANSLATION_MODEL=gpt-5.1
RT_SOURCE_LANGUAGE=zh
RT_TARGET_LANGUAGE=en
RT_DEVICE=auto
RT_COMPUTE_TYPE=int8
RT_BEAM_SIZE=1
RT_VAD_AGGRESSIVENESS=2
RT_MIN_SEGMENT_MS=700

# Company gateway (optional)
# OFFICETOOL_OPENAI_BASE_URL=https://your-company-gateway/v1
# OFFICETOOL_CA_CERT_PATH=C:/path/to/company-root-ca.pem
# OFFICETOOL_USE_RESPONSES_API=false

# Online mode (default if HF is reachable)
RT_WHISPER_MODEL=small

# Offline mode (preferred when the company machine cannot access HF)
# RT_WHISPER_MODEL_PATH=C:/models/faster-whisper-small
# RT_HF_LOCAL_FILES_ONLY=true

# HF mirror mode
# RT_HF_ENDPOINT=https://your-hf-mirror
# RT_HF_TOKEN=hf_xxx

# Optional local cache directory
# RT_HF_CACHE_DIR=C:/hf-cache

# Optional glossary
# RT_GLOSSARY=公司A=Company A\n产品B=Product B
